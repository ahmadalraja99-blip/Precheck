# docker-compose maps PostgreSQL to host port 5433.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/precheck_outcheck?schema=public"
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
API_PREFIX="api/v1"
STORAGE_ROOT="storage"

# SMTP is optional in local development. Leave SMTP_HOST empty to log EMAIL_FAILED without blocking the workflow.
SMTP_HOST=""
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="PreCheck System <no-reply@example.com>"

SEED_SUPER_ADMIN_EMAIL="super.admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!"
SEED_SUPER_ADMIN_FULL_NAME="System Super Admin"

DAILY_BACKUP_CRON="0 1 * * *"
WEEKLY_BACKUP_CRON="0 2 * * 1"
