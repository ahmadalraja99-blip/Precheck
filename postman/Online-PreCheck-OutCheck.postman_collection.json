        { "name": "Activate Check Item", "request": { "method": "PATCH", "url": "{{baseUrl}}/check-items/{{checkItemId}}/activate" } },
        { "name": "Deactivate Check Item", "request": { "method": "PATCH", "url": "{{baseUrl}}/check-items/{{checkItemId}}/deactivate" } }
