{
  "info": {
    "_postman_id": "3b138760-2aa4-4fd6-a24b-e64f595af31b",
    "name": "Online PreCheck / OutCheck",
    "description": "Backend API collection for Damascus International Airport Online PreCheck / OutCheck.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
