      { "name": "Submit OutCheck", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"results\": [{\n    \"counterId\": \"{{counterId}}\",\n    \"deviceId\": \"{{deviceId}}\",\n    \"checkItemId\": \"{{checkItemId}}\",\n    \"value\": \"OK\"\n  }]\n}" }, "url": "{{baseUrl}}/sessions/{{sessionId}}/outcheck/submit" } },
